  m_Script: {fileID: 11500000, guid: f11ba8a1b73669c47b22327f6a3cfb90, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  hierarchyNotes: "Hierarchy:\r\n\r\nRGBColorPicker\r\n |-- Cube\r\n      |-- RedPlane\r\n     
    |    O-- RGBPlaneView (Fixed Red)\r\n      |\r\n      |-- GreenPlane\r\n     
    |    O-- RGBPlaneView (Fixed Green)\r\n      |\r\n      |-- BluePlane\r\n          
    O-- RGBPlaneView (Fixed Blue)\r\n\r\nThe plane represents a 2D slice of RGB space.\r\nThe
    fixed channel comes from the picker.\r\nThe other two channels are selected by
    UV position."
  picker: {fileID: 9009853320384723123}
